# EarthOS environment variables — all optional.
# The platform runs entirely on keyless free public APIs without any of these.
# Copy to .env.local and fill in what you have to unlock the gated features.

# AI Analyst + AI briefings (Google Gemini API — https://aistudio.google.com/apikey).
# Without it the Analyst module explains how to enable itself; everything else works.
GEMINI_API_KEY=
# Optional model override (default: gemini-2.5-flash)
GEMINI_MODEL=

# Maritime live vessel positions (aishub.net free membership).
# Without it the Maritime module shows shipping news + a setup notice.
AISHUB_API_KEY=
