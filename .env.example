# EarthOS environment template
# Copy to .env.local — never commit secrets

# --- Required for production persistence (server-side only) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=

# Optional Supabase keys (prototype / client — not for open RLS writes)
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- AI (optional) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- Source API keys (optional, key-gated connectors) ---
AISHUB_API_KEY=
PRODUCTHUNT_API_TOKEN=
TOMTOM_API_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_KEY=

# --- Redis / Upstash (optional — distributed cache, queue, rate limits) ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Cloudflare R2 (optional — raw payload archive) ---
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET=earthos-raw

# --- ClickHouse (optional — production analytics only) ---
CLICKHOUSE_URL=
CLICKHOUSE_USER=
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=earthos

# --- OpenSearch (optional — Phase 2) ---
OPENSEARCH_URL=
OPENSEARCH_USERNAME=
OPENSEARCH_PASSWORD=

# --- Ingestion / admin ---
EARTHOS_INGEST_SECRET=
EARTHOS_ADMIN_SECRET=
EARTHOS_INGEST_URL=http://localhost:3000

# --- Feature flag overrides (optional) ---
# EARTHOS_FLAG_STRICT_RATE_LIMITS=true
# EARTHOS_FLAG_R2_ARCHIVE=false

# --- Cost / quota thresholds (optional overrides) ---
# EARTHOS_QUOTA_WARN_PCT=60
# EARTHOS_QUOTA_REDUCE_PCT=75
# EARTHOS_QUOTA_PAUSE_PCT=85
